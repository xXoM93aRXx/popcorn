<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Badge Tree View -->
    <record id="view_popcorn_badge_tree" model="ir.ui.view">
        <field name="name">popcorn.badge.tree</field>
        <field name="model">popcorn.badge</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="Badges">
                <field name="name"/>
                <field name="image" widget="image" options="{'size': [90, 90]}"/>
                <field name="badge_rule_ids" widget="many2many_tags"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Badge Form View -->
    <record id="view_popcorn_badge_form" model="ir.ui.view">
        <field name="name">popcorn.badge.form</field>
        <field name="model">popcorn.badge</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Badge">
                <header>
                    <button name="toggle_active" type="object" string="Archive" class="oe_highlight" 
                            invisible="active == False"/>
                    <button name="toggle_active" type="object" string="Unarchive" 
                            invisible="active == True"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Badge Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="image" widget="image" options="{'size': [200, 200]}"/>
                            <field name="image_filename" invisible="1"/>
                        </group>
                        <group>
                            <field name="description" placeholder="Badge Description"/>
                            <field name="active"/>
                            <field name="is_diversity_badge"/>
                            <field name="prize_popcorn_money"/>
                            <field name="prize_expiry_days"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Badge Rules" name="badge_rules">
                            <field name="badge_rule_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="model_id"/>
                                    <field name="field_id"/>
                                    <field name="operator"/>
                                    <field name="value"/>
                                    <field name="use_time_filter"/>
                                    <field name="time_filter_months"/>
                                    <field name="time_filter_anchor_date"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Badge Search View -->
    <record id="view_popcorn_badge_search" model="ir.ui.view">
        <field name="name">popcorn.badge.search</field>
        <field name="model">popcorn.badge</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search string="Search Badges">
                <field name="name"/>
                <field name="description"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_active" context="{'group_by': 'active'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Badge Rule Tree View -->
    <record id="view_popcorn_badge_rule_tree" model="ir.ui.view">
        <field name="name">popcorn.badge.rule.tree</field>
        <field name="model">popcorn.badge.rule</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="Badge Rules">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="badge_id"/>
                <field name="model_id"/>
                <field name="field_id"/>
                <field name="operator"/>
                <field name="value"/>
                <field name="remaining_text_template"/>
                <field name="use_time_filter"/>
                <field name="time_filter_months"/>
                <field name="time_filter_anchor_date"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Badge Rule Form View -->
    <record id="view_popcorn_badge_rule_form" model="ir.ui.view">
        <field name="name">popcorn.badge.rule.form</field>
        <field name="model">popcorn.badge.rule</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Badge Rule">
                <header>
                    <button name="toggle_active" type="object" string="Archive" class="oe_highlight" 
                            invisible="active == False"/>
                    <button name="toggle_active" type="object" string="Unarchive" 
                            invisible="active == True"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Rule Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="badge_id"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="model_id"/>
                            <field name="field_id"/>
                            <field name="operator"/>
                            <field name="value"/>
                            <field name="remaining_text_template" placeholder="{remaining} more to earn this badge"/>
                        </group>
                    </group>
                    <separator string="Time Filter"/>
                    <group>
                        <group>
                            <field name="use_time_filter"/>
                            <field name="time_filter_months" readonly="not use_time_filter"/>
                            <field name="time_filter_anchor_date" readonly="not use_time_filter"
                                  invisible="not use_time_filter"/>
                            <field name="time_filter_field" readonly="not use_time_filter"/>
                        </group>
                    </group>
                    <separator string="Note" invisible="not use_time_filter"/>
                    <group invisible="not use_time_filter">
                        <p class="o_row">
                            <i class="fa fa-info-circle"/> 
                            The window always rolls backwards <b>N months from today</b>.
                            If <b>Start Date</b> is set, it acts as the earliest date records can count from (program launch date) — the window never expires past it.
                        </p>
                    </group>
                    <group>
                        <field name="description" placeholder="Rule Description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Badge Rule Search View -->
    <record id="view_popcorn_badge_rule_search" model="ir.ui.view">
        <field name="name">popcorn.badge.rule.search</field>
        <field name="model">popcorn.badge.rule</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search string="Search Badge Rules">
                <field name="name"/>
                <field name="badge_id"/>
                <field name="model_id"/>
                <field name="field_id"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Badge" name="group_badge" context="{'group_by': 'badge_id'}"/>
                    <filter string="Model" name="group_model" context="{'group_by': 'model_id'}"/>
                    <filter string="Status" name="group_active" context="{'group_by': 'active'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Badge Prize List View -->
    <record id="view_popcorn_badge_prize_list" model="ir.ui.view">
        <field name="name">popcorn.badge.prize.list</field>
        <field name="model">popcorn.badge.prize</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="Badge Prizes"
                  decoration-muted="expired == True"
                  default_order="earned_date desc"
                  editable="bottom">
                <field name="partner_id"/>
                <field name="badge_id"/>
                <field name="amount"/>
                <field name="earned_date"/>
                <field name="expiry_date"/>
                <field name="expired"/>
            </list>
        </field>
    </record>

    <!-- Badge Prize Search View -->
    <record id="view_popcorn_badge_prize_search" model="ir.ui.view">
        <field name="name">popcorn.badge.prize.search</field>
        <field name="model">popcorn.badge.prize</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search string="Search Badge Prizes">
                <field name="partner_id"/>
                <field name="badge_id"/>
                <separator/>
                <filter string="Active" name="active" domain="[('expired', '=', False)]"/>
                <filter string="Expired" name="expired" domain="[('expired', '=', True)]"/>
                <filter string="Expiring Soon" name="expiring_soon"
                        domain="[('expired', '=', False), ('expiry_date', '!=', False), ('expiry_date', '&lt;=', (context_today() + datetime.timedelta(days=7)))]"/>
                <filter string="No Expiry" name="no_expiry" domain="[('expiry_date', '=', False)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Partner" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Badge" name="group_badge" context="{'group_by': 'badge_id'}"/>
                    <filter string="Earned Date" name="group_earned_date" context="{'group_by': 'earned_date:month'}"/>
                    <filter string="Status" name="group_expired" context="{'group_by': 'expired'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Badge Prize Action -->
    <record id="action_popcorn_badge_prize" model="ir.actions.act_window">
        <field name="name">Badge Prizes</field>
        <field name="res_model">popcorn.badge.prize</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_popcorn_badge_prize_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No badge prizes awarded yet!
            </p>
            <p>
                Prize records are created automatically when a partner earns a badge with a Popcorn Money prize.
            </p>
        </field>
    </record>

    <!-- Badge Actions -->
    <record id="action_popcorn_badge" model="ir.actions.act_window">
        <field name="name">Badges</field>
        <field name="res_model">popcorn.badge</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_popcorn_badge_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first badge!
            </p>
            <p>
                Badges are rewards that users can earn based on specific criteria.
                Define rules to automatically award badges to users who meet certain conditions.
            </p>
        </field>
    </record>

    <record id="action_popcorn_badge_rule" model="ir.actions.act_window">
        <field name="name">Badge Rules</field>
        <field name="res_model">popcorn.badge.rule</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_popcorn_badge_rule_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first badge rule!
            </p>
            <p>
                Badge rules define the criteria that users must meet to earn a badge.
                You can create rules based on any model and field in the system.
            </p>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_popcorn_badges" 
              name="Badges" 
              parent="menu_popcorn_root" 
              sequence="50"/>

    <menuitem id="menu_popcorn_badges_badges" 
              name="Badges" 
              parent="menu_popcorn_badges" 
              sequence="50"
              action="action_popcorn_badge"/>

    <menuitem id="menu_popcorn_badge_rules" 
              name="Badge Rules" 
              parent="menu_popcorn_badges" 
              sequence="10"
              action="action_popcorn_badge_rule"/>

    <menuitem id="menu_popcorn_badge_prizes"
              name="Badge Prizes"
              parent="menu_popcorn_badges"
              sequence="55"
              action="action_popcorn_badge_prize"/>

    <menuitem id="menu_popcorn_activity_sport"
              name="Activities &amp; Sports" 
              parent="menu_popcorn_badges" 
              sequence="60"
              action="action_popcorn_activity_sport"/>

    <menuitem id="menu_popcorn_activity_sport_category" 
              name="Activity/Sport Categories" 
              parent="menu_popcorn_badges" 
              sequence="70"
              action="action_popcorn_activity_sport_category"/>

</odoo>
