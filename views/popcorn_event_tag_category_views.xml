<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="popcorn_event_tag_category_view_form" model="ir.ui.view">
        <field name="name">popcorn.event.tag.category.form</field>
        <field name="model">event.tag.category</field>
        <field name="inherit_id" ref="event.event_tag_category_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="inside">
                <field name="controls_card_color"/>
            </xpath>
        </field>
    </record>

    <!-- Standalone list view for event.tag -->
    <record id="popcorn_event_tag_view_list" model="ir.ui.view">
        <field name="name">popcorn.event.tag.list</field>
        <field name="model">event.tag</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="Event Tags">
                <field name="name"/>
                <field name="category_id"/>
                <field name="constellation_name"/>
                <field name="constellation_image" widget="image" options="{'size': [40, 40]}"/>
            </list>
        </field>
    </record>

    <!-- Standalone form view for event.tag -->
    <record id="popcorn_event_tag_form_standalone" model="ir.ui.view">
        <field name="name">popcorn.event.tag.form.standalone</field>
        <field name="model">event.tag</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Event Tag">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tag Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="category_id"/>
                            <field name="color" widget="color_index"/>
                        </group>
                    </group>
                    <separator string="Variety Badge"/>
                    <group>
                        <group>
                            <field name="constellation_image" widget="image" options="{'size': [200, 200]}"/>
                            <field name="constellation_image_filename" invisible="1"/>
                        </group>
                        <group>
                            <field name="constellation_name" placeholder="e.g. Cygnus"/>
                            <field name="constellation_description" placeholder="Flavour text shown in the info card…"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action to open event.tag list -->
    <record id="action_popcorn_event_tag" model="ir.actions.act_window">
        <field name="name">Event Tags</field>
        <field name="res_model">event.tag</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('popcorn_event_tag_view_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('popcorn_event_tag_form_standalone')})]"/>
    </record>

    <!-- Menu item under Popcorn Badges -->
    <menuitem id="menu_popcorn_event_tags"
              name="Event Tags"
              parent="menu_popcorn_badges"
              sequence="65"
              action="action_popcorn_event_tag"/>
</odoo>
