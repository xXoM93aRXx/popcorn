<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Notification Settings Form View -->
        <record id="view_popcorn_notification_settings_form" model="ir.ui.view">
            <field name="name">popcorn.notification.settings.form</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//app[@name='popcorn']" position="inside">
                    <block title="Waitlist Promotion Settings">
                        <setting string="Waitlist Promotion Notification" 
                                 help="Select the notification to send when a user is promoted from waitlist to confirmed registration. This notification will be sent via WeChat if configured. Make sure to configure the WeChat template and field mappings in the notification record.">
                            <field name="waitlist_promotion_notification_id" 
                                   class="oe_inline"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

