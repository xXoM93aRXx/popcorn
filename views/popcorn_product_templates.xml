<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Override the checkout button on cart page to use WeChat direct payment -->
    <template id="popcorn_cart_checkout_button" inherit_id="website_sale.navigation_buttons" name="Popcorn Cart Checkout Button">
        <!-- Replace the checkout button on cart page only -->
        <xpath expr="//a[@name='website_sale_main_button']" position="replace">
            <a role="button" 
               name="website_sale_main_button"
               id="popcorn_buy_now_checkout_button"
               t-attf-class="#{_cta_classes} btn btn-primary #{not website_sale_order._is_cart_ready() and 'disabled'} #{_form_send_navigation and 'order-lg-3 w-100 w-lg-auto ms-lg-auto' or 'w-100'}"
               href="/shop/buy_now/checkout">
                <i class="fa fa-shopping-cart me-2"/> Buy Now with WeChat Pay
                <i class="fa fa-angle-right ms-2 fw-light"/>
            </a>
        </xpath>
    </template>
    
    <!-- Success page template -->
    <template id="product_buy_now_success" name="Product Buy Now Success">
        <t t-call="website.layout">
            <div class="container mt-5">
                <div class="row justify-content-center">
                    <div class="col-md-8">
                        <div class="alert alert-success text-center">
                            <h2><i class="fa fa-check-circle"/> Payment Successful!</h2>
                            <p class="lead">Your order has been confirmed.</p>
                        </div>
                        
                        <div class="card">
                            <div class="card-header">
                                <h4>Order Details</h4>
                            </div>
                            <div class="card-body">
                                <p><strong>Order Number:</strong> <span t-esc="order.name"/></p>
                                <p><strong>Transaction ID:</strong> <span t-esc="transaction.reference"/></p>
                                <p><strong>Amount Paid:</strong> <span t-esc="order.currency_id.symbol"/><span t-esc="order.amount_total"/></p>
                                <p><strong>Status:</strong> <span class="badge badge-success" t-esc="order.state"/></p>
                                
                                <div class="mt-3">
                                    <h5>Order Lines:</h5>
                                    <ul>
                                        <t t-foreach="order.order_line" t-as="line">
                                            <li>
                                                <span t-esc="line.product_id.name"/> - 
                                                <span t-esc="line.product_uom_qty"/> x 
                                                <span t-esc="order.currency_id.symbol"/><span t-esc="line.price_unit"/>
                                            </li>
                                        </t>
                                    </ul>
                                </div>
                                
                                <div class="mt-4">
                                    <a href="/shop" class="btn btn-primary">Continue Shopping</a>
                                    <a t-attf-href="/my/orders/{{ order.id }}" class="btn btn-secondary">View Order</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
