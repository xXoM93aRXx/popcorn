<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Portal My Badges Page -->
    <template id="portal_my_badges_page" name="My Badges Page">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            
            <div class="o_portal_my_badges">
                <div class="container">
                    <div class="row">
                        <div class="col-12">
                            <h2 class="mb-4"><span t-translation="on">My Badges</span></h2>
                            <div class="my-badges-container">
                                <div class="row">
                                    <t t-foreach="partner.badge_ids" t-as="badge">
                                        <div class="col-md-3 col-sm-6 col-xs-12 mb-3">
                                            <a t-if="badge.is_diversity_badge" href="/my/diversity" class="text-decoration-none">
                                                <div class="badge-card" t-att-class="'badge-card ' + ('earned' if badge.earned else 'not-earned')">
                                                    <div class="badge-image-container">
                                                        <img t-if="badge.image"
                                                             t-att-src="'/web/image/popcorn.badge/' + str(badge.id) + '/image'"
                                                             class="badge-image"
                                                             t-att-alt="badge.name"/>
                                                        <div t-if="not badge.image" class="badge-placeholder">
                                                            <i class="fa fa-trophy fa-3x"></i>
                                                        </div>
                                                    </div>
                                                    <div class="badge-info">
                                                        <h4 class="badge-name"><t t-esc="badge.name"/></h4>
                                                        <p class="badge-description" t-if="badge.description">
                                                            <t t-esc="badge.description"/>
                                                        </p>
                                                        <t t-set="remaining_text" t-value="badge.get_remaining_text_for_partner(partner)"/>
                                                        <p t-if="remaining_text" class="badge-remaining-text">
                                                            <t t-esc="remaining_text"/>
                                                        </p>
                                                        <div class="badge-status">
                                                            <span t-if="badge.earned" class="status-earned">
                                                                <i class="fa fa-check-circle"></i> Earned
                                                            </span>
                                                            <span t-else="" class="status-not-earned">
                                                                <i class="fa fa-clock-o"></i> Not Earned
                                                            </span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </a>
                                            <div t-else="" class="badge-card" t-att-class="'badge-card ' + ('earned' if badge.earned else 'not-earned')">
                                                <div class="badge-image-container">
                                                    <img t-if="badge.image"
                                                         t-att-src="'/web/image/popcorn.badge/' + str(badge.id) + '/image'"
                                                         class="badge-image"
                                                         t-att-alt="badge.name"/>
                                                    <div t-if="not badge.image" class="badge-placeholder">
                                                        <i class="fa fa-trophy fa-3x"></i>
                                                    </div>
                                                </div>
                                                <div class="badge-info">
                                                    <h4 class="badge-name"><t t-esc="badge.name"/></h4>
                                                    <p class="badge-description" t-if="badge.description">
                                                        <t t-esc="badge.description"/>
                                                    </p>
                                                    <t t-set="remaining_text" t-value="badge.get_remaining_text_for_partner(partner)"/>
                                                    <p t-if="remaining_text" class="badge-remaining-text">
                                                        <t t-esc="remaining_text"/>
                                                    </p>
                                                    <div class="badge-status">
                                                        <span t-if="badge.earned" class="status-earned">
                                                            <i class="fa fa-check-circle"></i> Earned
                                                        </span>
                                                        <span t-else="" class="status-not-earned">
                                                            <i class="fa fa-clock-o"></i> Not Earned
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                                <div t-if="not partner.badge_ids" class="no-badges">
                                    <div class="alert alert-info">
                                        <i class="fa fa-info-circle"></i>
                                        No badges available at the moment.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Portal Menu Item for Badges -->
    <template id="portal_my_badges_menu" name="Portal My Badges Menu" inherit_id="portal.portal_my_home">
        <xpath expr="//div[@id='portal_common_category']" position="after">
            <div class="o_portal_category row g-2 mt-3" id="portal_badges_category">
                <div class="o_portal_index_card col-md-6 order-2">
                    <a href="/my/badges" title="My Badges"
                    class="d-flex gap-2 gap-md-3 py-3 pe-2 px-md-3 h-100 rounded text-decoration-none bg-100">
                        <div class="o_portal_icon d-block align-self-start">
                            <img src="/popcorn/static/src/images/badges.png" loading="lazy" alt="Cards Icon" style="width: 80px; height: auto; object-fit: contain;"/>
                        </div>
                        <div>
                            <div class="mt-0 mb-1 fs-5 fw-normal lh-1 d-flex gap-2">
                                <span t-translation="on">My Badges</span>
                            </div>
                            <div class="opacity-75">
                                View your earned badges and achievements
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </xpath>
    </template>

    <!-- Diversity Badge Page -->
    <template id="portal_diversity_page" name="Diversity Badge Page">
        <t t-call="portal.portal_layout">
            <div class="o_portal_diversity">

                <!-- Progress header -->
                <div class="diversity-page-header mb-3">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                        <div>
                            <h2 class="mb-1">Diversity Badge</h2>
                            <p class="text-muted mb-0">Hover a host to preview them — attend their club to unlock</p>
                        </div>
                        <div class="diversity-counter-pill">
                            <span class="counter-num" t-esc="unlocked_count"/>
                            <span class="counter-sep">/</span>
                            <span class="counter-num text-muted" t-esc="total_count"/>
                            <span class="counter-label ms-1">Unlocked</span>
                        </div>
                    </div>
                    <div class="diversity-progress-wrap mt-2">
                        <div class="progress diversity-progress">
                            <div class="progress-bar"
                                 t-attf-style="width: {{ (unlocked_count / total_count * 100) if total_count else 0 }}%"/>
                        </div>
                    </div>
                </div>

                <!-- Stage: big background image + grid on top -->
                <div class="diversity-stage" t-if="hosts_data">

                    <!-- Background image layer -->
                    <img id="diversity-bg-img" class="diversity-bg-img" src="" alt=""/>
                    <div class="diversity-bg-no-img" id="diversity-bg-placeholder">
                        <i class="fa fa-user"/>
                    </div>

                    <!-- Gradient overlay so grid is always readable -->
                    <div class="diversity-stage-overlay"/>

                    <!-- Host name label (top-left, like MK) -->
                    <div class="diversity-host-label">
                        <div class="diversity-host-name" id="diversity-host-name">—</div>
                        <div class="diversity-host-status" id="diversity-host-status"></div>
                    </div>

                    <!-- Thumbnail grid anchored at the bottom -->
                    <div class="diversity-grid-panel">
                        <div class="diversity-thumb-grid">
                            <t t-foreach="hosts_data" t-as="entry">
                                <div t-attf-class="diversity-thumb {{ 'thumb-unlocked' if entry['unlocked'] else 'thumb-locked' }}"
                                     t-att-data-img="entry['img_src'] or ''"
                                     t-att-data-name="entry['host'].name"
                                     t-att-data-unlocked="'1' if entry['unlocked'] else '0'">
                                    <div class="diversity-thumb-inner">
                                        <t t-if="entry['img_src']">
                                            <img t-att-src="entry['img_src']"
                                                 class="diversity-thumb-img"
                                                 t-att-alt="entry['host'].name"/>
                                        </t>
                                        <t t-else="">
                                            <div class="diversity-thumb-no-img">
                                                <i class="fa fa-user"/>
                                            </div>
                                        </t>
                                        <div t-if="not entry['unlocked']" class="diversity-thumb-lock">
                                            <i class="fa fa-lock"/>
                                        </div>
                                    </div>
                                    <div class="diversity-thumb-label" t-esc="entry['host'].name"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <div t-if="not hosts_data" class="alert alert-info mt-3">
                    <i class="fa fa-info-circle me-1"/> No hosts available yet.
                </div>

            </div>

            <script type="text/javascript">
                (function () {
                    var thumbs = document.querySelectorAll('.diversity-thumb');
                    var bgImg = document.getElementById('diversity-bg-img');
                    var bgPlaceholder = document.getElementById('diversity-bg-placeholder');
                    var hostName = document.getElementById('diversity-host-name');
                    var hostStatus = document.getElementById('diversity-host-status');

                    function showHost(thumb) {
                        var imgSrc = thumb.dataset.img;
                        var name = thumb.dataset.name;
                        var unlocked = thumb.dataset.unlocked === '1';

                        if (imgSrc) {
                            bgImg.src = imgSrc;
                            bgImg.style.filter = unlocked ? '' : 'brightness(0)';
                            bgImg.style.display = 'block';
                            bgPlaceholder.style.display = 'none';
                        } else {
                            bgImg.style.display = 'none';
                            bgPlaceholder.style.display = 'flex';
                        }

                        hostName.textContent = name;
                        hostStatus.textContent = unlocked ? '✓ Unlocked' : 'Attend their club to unlock';

                        hostStatus.className = 'diversity-host-status ' + (unlocked ? 'status-unlocked' : 'status-locked');

                        thumbs.forEach(function (t) { t.classList.remove('thumb-active'); });
                        thumb.classList.add('thumb-active');
                    }

                    thumbs.forEach(function (thumb) {
                        thumb.addEventListener('mouseenter', function () { showHost(thumb); });
                        thumb.addEventListener('click', function () { showHost(thumb); });
                    });

                    if (thumbs.length > 0) { showHost(thumbs[0]); }
                })();
            </script>
        </t>
    </template>

    <!-- Badge Detail Modal -->
    <template id="badge_detail_modal" name="Badge Detail Modal">
        <div class="modal fade" id="badgeDetailModal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4 class="modal-title" id="badgeDetailModalLabel">Badge Details</h4>
                        <button type="button" class="close" data-dismiss="modal">
                            <span>&#215;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <div class="badge-detail-content">
                            <div class="badge-detail-image">
                                <img id="badgeDetailImage" class="img-responsive" style="max-width: 200px;"/>
                            </div>
                            <div class="badge-detail-info">
                                <h3 id="badgeDetailName"></h3>
                                <p id="badgeDetailDescription"></p>
                                <div class="badge-detail-status">
                                    <span id="badgeDetailStatus"></span>
                                </div>
                                <div class="badge-detail-rules">
                                    <h5>Requirements:</h5>
                                    <ul id="badgeDetailRules"></ul>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    </template>

</odoo>
