            <field name="active">True</field>
        </record>
        
        <!-- Badge: Diversity -->
        <record id="badge_diversity" model="popcorn.badge">
            <field name="name">Diversity</field>
            <field name="description">Attend events from at least 10 different hosts!</field>
            <field name="active">True</field>
        </record>
        
        <record id="badge_rule_diversity" model="popcorn.badge.rule">
            <field name="name">10 Distinct Hosts</field>
            <field name="badge_id" ref="badge_diversity"/>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="field_id" ref="popcorn.field_res_partner__distinct_hosts_count_in_period"/>
            <field name="operator">>=</field>
            <field name="value">10</field>
            <field name="use_time_filter" eval="True"/>
            <field name="time_filter_months" eval="12"/>
            <field name="time_filter_anchor_date">2025-01-01</field>
            <field name="time_filter_field">create_date</field>
            <field name="description">Attend events from at least 10 different hosts within the time period</field>
            <field name="active">True</field>
        </record>
        
    </data>
</odoo>
