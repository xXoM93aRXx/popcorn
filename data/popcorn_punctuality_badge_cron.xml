<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Punctuality Badge -->
        <record id="badge_punctuality_90d" model="popcorn.badge">
            <field name="name">Punctuality Badge</field>
            <field name="description">Always on time, never penalised — 5+ clean attendances every month for 90 days in a row.</field>
            <field name="active">True</field>
            <field name="prize_popcorn_money">100.0</field>
        </record>

        <!-- Daily cron: evaluate punctuality badge -->
        <record id="ir_cron_punctuality_badge" model="ir.cron">
            <field name="name">Popcorn: Evaluate Punctuality Badge</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model._cron_evaluate_punctuality_badge()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="priority">10</field>
        </record>

    </data>
</odoo>
