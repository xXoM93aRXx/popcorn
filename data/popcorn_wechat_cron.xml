<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_popcorn_wechat_notifications" model="ir.cron">
            <field name="name">Popcorn: Send WeChat Notifications</field>
            <field name="model_id" search="[('model', '=', 'popcorn.notification')]"/>
            <field name="state">code</field>
            <field name="code">model.cron_send_wechat_notifications()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="active">True</field>
        </record>
    </data>
</odoo>


