<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Activity/Sport Categories -->
        <record id="popcorn_activity_sport_category_activity" model="popcorn.activity_sport.category">
            <field name="name">Activity</field>
            <field name="sequence">10</field>
            <field name="active" eval="True"/>
            <field name="description">General activities and hobbies</field>
        </record>

        <record id="popcorn_activity_sport_category_sport" model="popcorn.activity_sport.category">
            <field name="name">Sport</field>
            <field name="sequence">20</field>
            <field name="active" eval="True"/>
            <field name="description">Physical sports and athletic activities</field>
        </record>

        <record id="popcorn_activity_sport_category_art" model="popcorn.activity_sport.category">
            <field name="name">Art &amp; Creative</field>
            <field name="sequence">30</field>
            <field name="active" eval="True"/>
            <field name="description">Creative and artistic activities</field>
        </record>

        <record id="popcorn_activity_sport_category_outdoor" model="popcorn.activity_sport.category">
            <field name="name">Outdoor</field>
            <field name="sequence">40</field>
            <field name="active" eval="True"/>
            <field name="description">Outdoor activities and adventures</field>
        </record>
    </data>
</odoo>

