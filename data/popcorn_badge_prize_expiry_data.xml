<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Scheduled Action: Expire badge prize Popcorn Money -->
        <record id="ir_cron_badge_prize_expiry" model="ir.cron">
            <field name="name">Popcorn: Expire Badge Prize Money</field>
            <field name="model_id" ref="model_popcorn_badge_prize"/>
            <field name="state">code</field>
            <field name="code">model._cron_expire_badge_prizes()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="priority">5</field>
        </record>

    </data>
</odoo>
